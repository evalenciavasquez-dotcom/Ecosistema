# Contraseña de acceso al sistema privado.
# Si no se define, se usa el valor por defecto "cco-ev-2026" (cámbialo en producción).
APP_PASSWORD=cambia-esta-contrasena

# API key de Anthropic (console.anthropic.com -> Settings -> API Keys).
# Necesaria para el botón "Analizar con IA" en Decisiones. Sin ella, ese botón
# muestra un error en vez de fallar silenciosamente.
ANTHROPIC_API_KEY=sk-ant-...
