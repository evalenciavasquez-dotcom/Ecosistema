# Contraseña de acceso al sistema privado.
# Si no se define, se usa el valor por defecto "cco-ev-2026" (cámbialo en producción).
APP_PASSWORD=cambia-esta-contrasena

# API key de Anthropic (console.anthropic.com -> Settings -> API Keys).
# Necesaria para el botón "Analizar con IA" en Decisiones. Sin ella, ese botón
# muestra un error en vez de fallar silenciosamente.
ANTHROPIC_API_KEY=sk-ant-...

# URL de conexión a Postgres (Neon en producción, Postgres local en desarrollo).
# Sin esta variable, la app funciona igual que antes: todo vive en localStorage
# del navegador, sin sincronizar entre dispositivos.
# Con esta variable configurada, la app persiste en la base de datos y la misma
# información aparece en cualquier dispositivo donde entres.
# Cómo obtenerla en producción (Vercel + Neon):
#   1. En el proyecto de Vercel, pestaña "Storage" -> "Create Database" -> "Neon Postgres".
#   2. Vercel crea la base y añade DATABASE_URL automáticamente a las variables de entorno.
#   3. Vuelve a desplegar. En Configuración, dentro de la app, aparecerá la opción
#      para migrar los datos actuales a la base de datos.
DATABASE_URL=postgresql://usuario:password@host/basededatos
