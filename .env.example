# Contraseña de acceso al sistema privado.
# Si no se define, se usa el valor por defecto "cco-ev-2026" (cámbialo en producción).
APP_PASSWORD=cambia-esta-contrasena

# API key de Anthropic (console.anthropic.com -> Settings -> API Keys).
# Necesaria para el botón "Analizar con IA" en Decisiones. Sin ella, ese botón
# muestra un error en vez de fallar silenciosamente.
ANTHROPIC_API_KEY=sk-ant-...

# URL de conexión a Postgres (Neon en producción, Postgres local en desarrollo).
# Sin esta variable, la app funciona igual que antes: todo vive en localStorage
# del navegador, sin sincronizar entre dispositivos.
# Con esta variable configurada, la app persiste en la base de datos y la misma
# información aparece en cualquier dispositivo donde entres.
# Cómo obtenerla en producción (Vercel + Neon):
#   1. En el proyecto de Vercel, pestaña "Storage" -> "Create Database" -> "Neon Postgres".
#   2. Vercel crea la base y añade DATABASE_URL automáticamente a las variables de entorno.
#   3. Vuelve a desplegar. En Configuración, dentro de la app, aparecerá la opción
#      para migrar los datos actuales a la base de datos.
DATABASE_URL=postgresql://usuario:password@host/basededatos

# Conexión con Google (Gmail + Calendar). Necesaria para el botón "Conectar
# con Google" en Configuración. Sin estas variables, esa sección explica
# que falta configurarlas en vez de fallar en silencio.
# Cómo obtenerlas:
#   1. console.cloud.google.com -> crea un proyecto.
#   2. "APIs y servicios" -> "Biblioteca" -> activa "Gmail API" y "Google Calendar API".
#   3. "APIs y servicios" -> "Pantalla de consentimiento OAuth" -> tipo "Externo",
#      modo "Testing" (así evitas el proceso de verificación de Google — solo
#      tú, como usuario de prueba, puedes autorizar la app).
#   4. "Credenciales" -> "Crear credenciales" -> "ID de cliente de OAuth" ->
#      tipo "Aplicación web". En "URIs de redirección autorizados" agrega
#      exactamente el valor de GOOGLE_REDIRECT_URI de abajo (con tu dominio real).
#   5. Copia el ID de cliente y el secreto aquí.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://tu-dominio.vercel.app/api/google/callback

# VINCERE Intelligence Platform — registro a Notion (opcional).
# El botón "Registrar en Notion" dentro de /vincere escribe una página en una
# base de datos de Notion si estas dos variables están configuradas. Sin ellas,
# la plataforma sigue funcionando y solo avisa que Notion no está configurado.
# Cómo obtenerlas:
#   1. notion.so/my-integrations -> "New integration" (interna) -> copia el token.
#   2. Crea una base de datos en Notion con una propiedad de título "Name"
#      (opcionalmente propiedades de texto "Proyecto", "Sección", "Detalle").
#   3. En la base, menú "..." -> "Connections" -> conecta tu integración.
#   4. Copia el id de la base de datos desde su URL (la parte de 32 caracteres).
# La interpretación de IA de VINCERE (lectura por sección, preguntas, triage)
# usa la misma ANTHROPIC_API_KEY de arriba.
NOTION_TOKEN=secret_xxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
